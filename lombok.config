# Stop Lombok from looking for config files further up the filesystem.
config.stopBubbling = true

# Copy Spring's injection annotations onto the constructor parameters that
# Lombok generates (e.g. for @RequiredArgsConstructor), so field-level
# @Value("${...}") and @Qualifier still drive injection.
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
