# These env variables are used by the Spring Boot app to configure its OAuth clients and
# to connect to PingFederate. They are also used by configure.sh to create the
# clients automatically on first start.

# PingFederate admin credentials
PF_ADMIN_USER=administrator
PF_ADMIN_PASSWORD=Admin1234!


# OIDC Authorization Code client
OIDC_CLIENT_ID=demo-oidc-client
OIDC_CLIENT_SECRET=OidcSecret123!


# Resource Server/token introspection credentials
RS_CLIENT_ID=demo-rs-client
RS_CLIENT_SECRET=RsSecret123!


# Machine-to-Machine client credentials
M2M_CLIENT_ID=demo-m2m-client
M2M_CLIENT_SECRET=M2mSecret123!

PF_ISSUER_URI=https://localhost:9031
PF_AUTH_URI=https://localhost:9031